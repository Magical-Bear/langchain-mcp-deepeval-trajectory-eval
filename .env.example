# ============================================================
# LangChain MCP Agent 配置
# ============================================================

# Moonshot API Key (Kimi K2.5)
# 获取地址: https://platform.moonshot.cn/
MOONSHOT_API_KEY=your_moonshot_api_key_here

# Moonshot API Base URL
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# Kimi 模型名称
MOONSHOT_MODEL=kimi-k2-5

# ============================================================
# 跨 Session 记忆配置
# ============================================================

# 分类器模型：判断当前消息是否与历史 session 关联（y/n 二分类）
CLASSIFIER_MODEL=kimi-k2-turbo-preview

# 上下文压缩模型：历史超过 3 轮时压缩为摘要，减少 token 消耗
COMPRESSOR_MODEL=kimi-k2-0905-preview

# ============================================================
# 高德 MCP 配置 (streamable-http)
# ============================================================

# 高德 MCP Key
# 获取地址: https://mcp.amap.com/
AMAP_MCP_KEY=your_amap_mcp_key_here

# 高德 MCP URL (streamable-http)
AMAP_MCP_URL=https://mcp.amap.com/mcp?key=${AMAP_MCP_KEY}

# ============================================================
# 自定义 MCP 服务配置 (streamable-http)
# ============================================================

# 自定义 MCP 服务 URL
CUSTOM_MCP_URL=http://localhost:8000/mcp

# 自定义 MCP 服务端口
CUSTOM_MCP_PORT=8000

# langSmith API KEY
LANGSMITH_API_KEY=

# ============================================================
# 视觉理解子 Agent 配置（支持多模态）
# ============================================================

# vision 模型提供者：openai / google_genai / anthropic
VISION_MODEL_PROVIDER=openai

# vision 模型名称（必须支持 vision）：
# - openai (OpenRouter): openai/gpt-4o-mini, anthropic/claude-3.5-sonnet, google/gemini-1.5-flash
# - google_genai: gemini-1.5-pro, gemini-1.5-flash
# - anthropic: claude-3-5-sonnet-20241022, claude-3-sonnet-20240229
VISION_MODEL=openai/gpt-4o-mini

# OpenAI API 配置（OpenRouter base URL + API key）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Google API 配置（若 VISION_MODEL_PROVIDER=google_genai）
GOOGLE_API_KEY=

# Anthropic API 配置（若 VISION_MODEL_PROVIDER=anthropic）
ANTHROPIC_API_KEY=

# ============================================================
# LangGraph Agent Client 配置
# ============================================================

# LangGraph 服务器地址
LANGGRAPH_BASE_URL=http://localhost:2024

# Assistant ID（首次启动 langgraph dev 后自动生成，通过 /assistants/search 查询）
LANGGRAPH_ASSISTANT_ID=my_mcp_agent